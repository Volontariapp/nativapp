{
  "name": "@monorepo/mobile",
  "version": "0.1.0",
  "private": true,
  "description": "spendApp React Native mobile application (Expo SDK 54)",
  "license": "UNLICENSED",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "start:local": "NODE_ENV=local expo start",
    "start:dev": "NODE_ENV=development expo start",
    "start:test": "NODE_ENV=test expo start",
    "start:prod": "NODE_ENV=production expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint src/",
    "ts:check": "tsc --noEmit",
    "prebuild": "expo prebuild",
    "build:ios": "eas build --platform ios",
    "build:android": "eas build --platform android"
  },
  "packageManager": "yarn@4.12.0",
  "engines": {
    "node": ">=24.14.0"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@volontariapp/config": "2.1.0",
    "@volontariapp/contracts": "4.0.7",
    "@volontariapp/logger": "0.2.3",
    "@volontariapp/shared": "0.3.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "expo": "~54.0.34",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-is": "^19.2.4",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "react-native-worklets-core": "^1.6.3",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@eslint/js": "^9.18.0",
    "@types/react": "~19.1.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "@volontariapp/config": "2.1.0",
    "@volontariapp/contracts": "4.0.7",
    "@volontariapp/logger": "0.2.3",
    "@volontariapp/shared": "0.3.0",
    "eslint": "~9.18.0",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.2",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.19.1"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "**/*.{js,jsx,ts,tsx,json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
